# ─── LLM Provider (set ONE block) ─────────────────────────────────────────────
# "openai" | "anthropic" | "ollama"
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-abcdef1234567890abcdef1234567890abcdef12
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic (alternative — uncomment to use)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Ollama (local, no key required — uncomment to use)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ─── Embedding Provider ────────────────────────────────────────────────────────
# "openai" | "huggingface" | "ollama"
EMBEDDING_PROVIDER=huggingface
HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ─── Vector Database ───────────────────────────────────────────────────────────
# "chroma" | "qdrant" | "pgvector"
VECTOR_STORE_PROVIDER=chroma

# Chroma (local default)
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_PERSIST_DIR=./data/chroma
ANONYMIZED_TELEMETRY=False

# Qdrant (cloud or self-hosted — uncomment to use)
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# PGVector (Postgres — uncomment to use)
# PGVECTOR_DSN=postgresql://user:password@localhost:5432/ragdb

# ─── Redis (session / rate-limit cache — optional) ─────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── FastAPI ───────────────────────────────────────────────────────────────────
APP_ENV=development           # development | production
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=INFO

# ─── Security ──────────────────────────────────────────────────────────────────
# Bearer token used for authorization header: Bearer <API_TOKEN>
API_TOKEN=dev-token
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ─── Ingestion Defaults ────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_UPLOAD_MB=50

# ─── Retrieval Defaults ────────────────────────────────────────────────────────
TOP_K=4
